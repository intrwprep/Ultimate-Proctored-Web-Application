{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["exam_id", "title", "duration_minutes", "questions"],
  "properties": {
    "exam_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "duration_minutes": {"type": "integer", "minimum": 1},
    "signature": {"type": "string"},
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "question", "marks"],
        "properties": {
          "id": {"type": "string"},
          "type": {
            "type": "string",
            "enum": ["mcq_single", "mcq_multiple", "short_answer", "essay"]
          },
          "question": {"type": "string"},
          "options": {"type": "array", "items": {"type": "string"}},
          "correct_answer": {},
          "marks": {"type": "integer", "minimum": 1},
          "difficulty": {"type": "string", "enum": ["easy", "medium", "hard"]},
          "tags": {"type": "array", "items": {"type": "string"}},
          "time_limit_seconds": {"type": "integer", "minimum": 10},
          "image": {"type": "string"},
          "max_words": {"type": "integer", "minimum": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"type": {"const": "mcq_single"}}},
            "then": {
              "required": ["options", "correct_answer"],
              "properties": {"correct_answer": {"type": "string"}}
            }
          },
          {
            "if": {"properties": {"type": {"const": "mcq_multiple"}}},
            "then": {
              "required": ["options", "correct_answer"],
              "properties": {
                "correct_answer": {"type": "array", "items": {"type": "string"}, "minItems": 1}
              }
            }
          },
          {
            "if": {"properties": {"type": {"enum": ["short_answer", "essay"]}}},
            "then": {
              "properties": {
                "max_words": {"type": "integer", "minimum": 1}
              }
            }
          }
        ]
      }
    }
  }
}
